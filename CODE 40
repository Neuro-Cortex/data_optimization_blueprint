-- 15. Sample Queries
-- List all students
SELECT * FROM Students;

-- List all professors in CS department
SELECT ProfName FROM Professors WHERE DeptID = 1;

-- Get all courses with credits > 3
SELECT CourseName FROM Courses WHERE Credits > 3;

-- Join Students and Departments
SELECT s.StudentName, d.DeptName
FROM Students s
JOIN Departments d ON s.DeptID = d.DeptID;

-- Join Enrollments and Courses
SELECT e.StudentID, c.CourseName, e.Grade
FROM Enrollments e
JOIN Courses c ON e.CourseID = c.CourseID;

-- Average student age
SELECT AVG(Age) AS AvgAge FROM Students;

-- Count students per department
SELECT DeptID, COUNT(*) AS NumStudents
FROM Students
GROUP BY DeptID;

-- List students with grade A
SELECT s.StudentName, c.CourseName
FROM Enrollments e
JOIN Students s ON e.StudentID = s.StudentID
JOIN Courses c ON e.CourseID = c.CourseID
WHERE e.Grade = 'A';

-- Top 3 highest paid professors
SELECT ProfName, Salary
FROM Professors
ORDER BY Salary DESC
LIMIT 3;


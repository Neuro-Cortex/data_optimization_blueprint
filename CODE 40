-- Create view of student enrollments
CREATE VIEW StudentEnrollments AS
SELECT s.StudentName, c.CourseName, e.Grade
FROM Students s
JOIN Enrollments e ON s.StudentID = e.StudentID
JOIN Courses c ON e.CourseID = c.CourseID;


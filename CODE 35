SELECT p.category, p.product_name, SUM(oi.quantity) AS total_sold
FROM products p
JOIN order_items oi ON p.product_id = oi.product_id
GROUP BY p.category, p.product_name
HAVING total_sold = (
    SELECT MAX(total)
    FROM (
        SELECT SUM(oi2.quantity) AS total
        FROM products p2
        JOIN order_items oi2 ON p2.product_id = oi2.product_id
        WHERE p2.category = p.category
        GROUP BY p2.product_name
    ) AS sub
);
